[Unit]
Description=Update and publish Avanza portfolio snapshot
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/Documents/portfolio-tracker
ExecStart=%h/Documents/portfolio-tracker/scripts/update_and_publish.sh

# Hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=%h/Documents/portfolio-tracker

[Install]
WantedBy=default.target
